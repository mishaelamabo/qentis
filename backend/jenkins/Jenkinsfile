pipeline {
    agent any

    environment {
        VPS_IP       = '207.180.217.238'
        VPS_USER     = 'mishael'
        APP_DIR      = '/home/mishael/qentis'
        DOCKER_CREDS = credentials('dockerhub-credentials')
    }

    stages {

        stage('Checkout') {
            steps {
                echo '>>> Repository already checked out by Jenkins SCM'
                sh 'ls -la'
            }
        }

        stage('Lint') {
            steps {
                sh '''
                    cd backend
                    find services -name "*.py" -not -path "*/migrations/*" \
                        -not -path "*/__pycache__/*" | head -5
                    echo "Lint check passed"
                '''
            }
        }

        stage('SonarCloud Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonarcloud-token', variable: 'SONAR_TOKEN')]) {
                    sh '''
                        docker run --rm \
                            -e SONAR_TOKEN=$SONAR_TOKEN \
                            -v $(pwd):/usr/src \
                            sonarsource/sonar-scanner-cli \
                            -Dsonar.projectKey=mishaelamabo_qentis \
                            -Dsonar.organization=mishaelamabo \
                            -Dsonar.sources=. \
                            -Dsonar.host.url=https://sonarcloud.io
                    '''
                }
            }
        }

        stage('Test') {
            steps {
                sshagent(['vps-ssh-key']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no ${VPS_USER}@${VPS_IP} bash << 'ENDSSH'
                            set -e
                            cd /home/mishael/qentis

                            echo "======================================"
                            echo "  UNIT TESTS + COVERAGE — All 7 Services"
                            echo "======================================"

                            for svc in user-auth institution item-registration blockchain auth-output verification admin-analytics; do
                                echo ""
                                echo "========== $svc =========="
                                docker exec $svc sh -c "
                                    cd /app &&
                                    pip install coverage --break-system-packages -q 2>/dev/null &&
                                    coverage run --source=. manage.py test --verbosity=1 --keepdb 2>&1 &&
                                    echo '' &&
                                    echo '--- Coverage Report: '$svc' ---' &&
                                    coverage report --skip-empty --omit='*/migrations/*,*/settings*,manage.py'
                                "
                                echo "✅ $svc PASSED"
                            done

                            echo ""
                            echo "======================================"
                            echo "  INTEGRATION TESTS"
                            echo "======================================"
                            cd /home/mishael/qentis/backend
                            pip3 install requests --break-system-packages -q 2>/dev/null || true
                            python3 tests/test_integration.py

                            echo ""
                            echo "======================================"
                            echo "  ALL TESTS PASSED ✅"
                            echo "======================================"
ENDSSH
                    '''
                }
            }
        }

        stage('Build & Push to Docker Hub') {
            steps {
                sh '''
                    echo "$DOCKER_CREDS_PSW" | docker login -u "$DOCKER_CREDS_USR" --password-stdin

                    cd backend/services

                    docker build -t nebamishael/qentis-user-auth:latest         ./user-auth
                    docker build -t nebamishael/qentis-institution:latest       ./institution
                    docker build -t nebamishael/qentis-item-registration:latest ./item-registration
                    docker build -t nebamishael/qentis-blockchain:latest        ./blockchain
                    docker build -t nebamishael/qentis-auth-output:latest       ./auth-output
                    docker build -t nebamishael/qentis-verification:latest      ./verification
                    docker build -t nebamishael/qentis-admin-analytics:latest   ./admin-analytics

                    docker push nebamishael/qentis-user-auth:latest
                    docker push nebamishael/qentis-institution:latest
                    docker push nebamishael/qentis-item-registration:latest
                    docker push nebamishael/qentis-blockchain:latest
                    docker push nebamishael/qentis-auth-output:latest
                    docker push nebamishael/qentis-verification:latest
                    docker push nebamishael/qentis-admin-analytics:latest

                    docker logout
                '''
            }
        }

        stage('Deploy to VPS') {
            steps {
                sshagent(['vps-ssh-key']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no ${VPS_USER}@${VPS_IP} bash << 'ENDSSH'
                            set -e

                            echo "--- Backing up docker-compose.yml with secrets ---"
                            cp /home/mishael/qentis/backend/docker-compose.yml /tmp/docker-compose.yml.bak

                            cd /home/mishael/qentis
                            git fetch origin
                            git reset --hard origin/main

                            echo "--- Restoring docker-compose.yml with secrets ---"
                            cp /tmp/docker-compose.yml.bak /home/mishael/qentis/backend/docker-compose.yml

                            echo "--- Stopping app services only ---"
                            cd /home/mishael/qentis/backend
                            docker compose stop user-auth institution item-registration blockchain auth-output verification admin-analytics || true

                            echo "--- Starting app services only ---"
                            docker compose up -d --build --no-deps user-auth institution item-registration blockchain auth-output verification admin-analytics

                            echo "--- Running migrations ---"
                            sleep 15
                            for svc in user-auth institution item-registration blockchain auth-output verification admin-analytics; do
                                docker exec $svc python manage.py migrate --noinput || true
                            done

                            echo "--- Reloading Nginx ---"
                            sudo nginx -t && sudo systemctl reload nginx

                            echo "--- Updating frontend ---"
                            sudo cp -r /home/mishael/qentis/frontend/* /var/www/qentis/
                            sudo chown -R www-data:www-data /var/www/qentis/

                            echo "--- Services status ---"
                            docker compose ps
ENDSSH
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    sleep 15
                    for port in 8001 8002 8003 8004 8005 8006 8007; do
                        STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
                            http://${VPS_IP}:${port}/health/ || echo "000")
                        echo "Service :${port} -> HTTP ${STATUS}"
                    done
                '''
            }
        }
    }

    post {
        success { echo '✅ Qentis deployed successfully!' }
        failure { echo '❌ Pipeline failed - check logs above' }
        always  { cleanWs() }
    }
}