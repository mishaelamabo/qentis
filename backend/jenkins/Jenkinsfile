pipeline {
    agent any

    environment {
        VPS_IP       = '207.180.217.238'
        VPS_USER     = 'mishael'
        APP_DIR      = '/home/mishael/qentis'
        REPO_URL     = 'https://github.com/DanielLeo09/qentis.git'
        DOCKER_USER  = 'nebamishael'
        DOCKER_PASS  = credentials('dockerhub-credentials')
    }

    stages {

        stage('Checkout') {
            steps {
                echo '>>> Cloning repository...'
                git branch: 'main', url: "${REPO_URL}"
            }
        }

        stage('Lint') {
            steps {
                sh '''
                    pip install flake8 --quiet || true
                    cd backend
                    for service in services/*/; do
                        echo "Linting $service"
                        flake8 "$service" --max-line-length=120 \
                            --exclude=migrations,__pycache__ || true
                    done
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    pip install pytest pytest-django pytest-cov --quiet || true
                    cd backend
                    if [ -f tests/run_tests.sh ]; then
                        bash tests/run_tests.sh
                    else
                        echo "No test runner yet, skipping..."
                    fi
                '''
            }
        }

        stage('Build & Push to Docker Hub') {
            steps {
                sh '''
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin

                    cd backend/services

                    docker build -t nebamishael/qentis-user-auth:latest        ./user-auth
                    docker build -t nebamishael/qentis-institution:latest      ./institution
                    docker build -t nebamishael/qentis-item-registration:latest ./item-registration
                    docker build -t nebamishael/qentis-blockchain:latest       ./blockchain
                    docker build -t nebamishael/qentis-auth-output:latest      ./auth-output
                    docker build -t nebamishael/qentis-verification:latest     ./verification
                    docker build -t nebamishael/qentis-admin-analytics:latest  ./admin-analytics

                    docker push nebamishael/qentis-user-auth:latest
                    docker push nebamishael/qentis-institution:latest
                    docker push nebamishael/qentis-item-registration:latest
                    docker push nebamishael/qentis-blockchain:latest
                    docker push nebamishael/qentis-auth-output:latest
                    docker push nebamishael/qentis-verification:latest
                    docker push nebamishael/qentis-admin-analytics:latest

                    docker logout
                '''
            }
        }

        stage('Deploy to VPS') {
            steps {
                sshagent(['vps-ssh-key']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no ${VPS_USER}@${VPS_IP} "
                            set -e
                            cd ${APP_DIR} && git pull origin main
                            cd ${APP_DIR}/backend && docker compose stop
                            docker compose up -d --build
                            sleep 10
                            for svc in user-auth institution item-registration blockchain auth-output verification admin-analytics; do
                                docker exec \$svc python manage.py migrate --noinput || true
                            done
                            sudo nginx -t && sudo systemctl reload nginx
                            docker compose ps
                        "
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    sleep 15
                    for port in 8001 8002 8003 8004 8005 8006 8007; do
                        STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
                            http://${VPS_IP}:${port}/health/ || echo "000")
                        echo "Service :${port} -> HTTP ${STATUS}"
                    done
                '''
            }
        }
    }

    post {
        success { echo '✅ Qentis deployed successfully!' }
        failure { echo '❌ Pipeline failed - check logs above' }
        always  { cleanWs() }
    }
}